{
  "name": "unlockit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install",
    "docker": "docker compose --env-file .env.development -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose --env-file .env.development -f docker-compose.dev.yml down -v",
    "docker:db": "docker compose --env-file .env.development -f docker-compose.dev.yml up --build db",
    "docker:db:down": "docker compose --env-file .env.development -f docker-compose.dev.yml down -v db",
    "dev:migration:run": "dotenv -e .env.development -- npx --workspace=backend typeorm migration:run -d database/data-source.js",
    "dev:migration:revert": "dotenv -e .env.development -- npx --workspace=backend typeorm migration:revert -d database/data-source.js",
    "dev:migration:show": "dotenv -e .env.development -- npx --workspace=backend typeorm migration:show -d database/data-source.js",
    "dev": "NODE_ENV=development concurrently -k -p \"[{name}]\" -n \"SHARED,FRONT,BACK\" -c \"magenta,cyan,green\" \"npm run dev:shared\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:shared": "npm run build --workspace=@unlockit/shared -- --watch",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "NODE_ENV=development npm run start:dev --workspace=backend",
    "build:migration:run": "dotenv -e .env.production -- npx --workspace=backend typeorm migration:run -d database/data-source.js",
    "build:migration:revert": "dotenv -e .env.production -- npx --workspace=backend typeorm migration:revert -d database/data-source.js",
    "build:migration:show": "dotenv -e .env.production -- npx --workspace=backend typeorm migration:show -d database/data-source.js",
    "build": "npm run build:shared && concurrently \"npm run build:frontend\" \"npm run build:backend\"",
    "build:shared": "npm run build --workspace=@unlockit/shared",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "start": "concurrently -k -p \"[{name}]\" -n \"FRONT,BACK\" -c \"cyan,green\" \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "npm run start --workspace=frontend",
    "start:backend": "npm run start --workspace=backend",
    "generate:docs:backend": "npm run compodoc --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0"
  }
}
